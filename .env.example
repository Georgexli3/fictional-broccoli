# Buoyant proxy — token sent separately by Eric.
# The same token works for both Anthropic and OpenAI endpoints.
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://hiring-proxy.trybuoyant.ai/anthropic
# OPENAI_BASE_URL=https://hiring-proxy.trybuoyant.ai/openai   # not used in V1; available if you want to swap providers

# Vercel storage — auto-injected when Blob/KV are provisioned in the Vercel dashboard.
# For local dev, set these manually after running `vercel link` and `vercel env pull`.
BLOB_READ_WRITE_TOKEN=
KV_REST_API_URL=
KV_REST_API_TOKEN=

# App env. Used by /api/health to label responses.
NEXT_PUBLIC_APP_ENV=development
